# BasiCall Sync env
# Kopieer naar .env op de VPS: cp .env.example .env && nano .env
# Chmod 600 .env (alleen sitejob-tt mag lezen)

# Supabase project tvsdbztjqksxybxjwtrf
SUPABASE_URL=https://tvsdbztjqksxybxjwtrf.supabase.co

# Service role key (NOOIT in Git, NOOIT naar frontend). Haal uit Supabase dashboard:
# Settings -> API -> service_role (secret)
SUPABASE_SERVICE_KEY=

# Optioneel: override timezone (default Europe/Amsterdam via process.env.TZ in sync.js)
# TZ=Europe/Amsterdam
